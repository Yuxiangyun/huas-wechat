page {
  background: #F9F9FB;
  /* 极浅的冷灰色，比纯白背景更有质感 */
}

.about-container {
  min-height: 100vh;
  /* 底部安全区适配 */
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 头部区域 */
.hero-section {
  padding: 100rpx 48rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  /* 左对齐 */
}

.title-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.title-black {
  font-size: 72rpx;
  font-weight: 800;
  /* 加大字重 */
  color: #111111;
  letter-spacing: 2rpx;
}

.title-yellow {
  font-size: 72rpx;
  font-weight: 800;
  color: #111111;
  position: relative;
  z-index: 1;
  letter-spacing: 2rpx;
}

.title-yellow::after {
  content: '';
  position: absolute;
  left: 0;
  right: -8rpx;
  bottom: 8rpx;
  height: 28rpx;
  background: #D2FF72;
  z-index: -1;
  border-radius: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #888888;
  font-weight: 600;
  text-transform: uppercase;
  /* 英文大写 */
  letter-spacing: 4rpx;
  /* 宽字间距 */
}

/* 内容区域 */
.content-area {
  padding: 0 32rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  padding: 0 16rpx 16rpx;
  font-size: 22rpx;
  color: #AAAAAA;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* 内缩卡片 */
.list-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  /* 极弱的描边替代阴影 */
  overflow: hidden;
  /* 防止内容超出圆角 */
}

/* 列表行：采用 Flex 左右布局 */
.list-row {
  position: relative;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
  transition: background-color 0.2s ease;
}

.list-row:last-child {
  border-bottom: none;
}

/* 点击态 */
.row-hover {
  background-color: #F4F4F5 !important;
}

/* Button 彻底重置 */
.list-row-btn {
  margin: 0 !important;
  width: 100% !important;
  min-height: 0 !important;
  background: transparent !important;
  border-radius: 0 !important;
  text-align: left !important;
  line-height: normal !important;
  box-sizing: border-box !important;
  -webkit-appearance: none;
}

.list-row-btn::after {
  border: none !important;
  display: none !important;
}

/* 列表文本内容区 */
.list-content {
  flex: 1;
  padding-right: 32rpx;
  /* 文本和右侧 Tag 的间距 */
}

.list-row-label {
  display: block;
  font-size: 30rpx;
  color: #111111;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.list-row-hint,
.list-row-desc {
  display: block;
  font-size: 24rpx;
  color: #888888;
  line-height: 1.4;
}

.list-row-text {
  font-size: 28rpx;
  color: #444444;
  font-weight: 500;
}

/* 胶囊标签 (Pill Shape) */
.list-row-tag {
  flex-shrink: 0;
  background: #D2FF72;
  color: #111111;
  font-size: 22rpx;
  font-weight: 700;
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* 免责声明 */
.disclaimer-row {
  padding: 32rpx;
}

.disclaimer-row text {
  font-size: 24rpx;
  color: #AAAAAA;
  line-height: 1.6;
}

/* 底部 Footer */
.footer {
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: center;
}

.footer-text {
  font-size: 22rpx;
  color: #BBBBBB;
  font-weight: 500;
  letter-spacing: 1rpx;
}