/* login.wxss - 登录页样式 */

/* 引入 CSS 变量，提升维护性，为未来深色模式做准备 */
page {
  --primary-color: #D2FF72;
  --primary-color-light: rgba(210, 255, 114, 0.2);
  --primary-color-shadow: rgba(210, 255, 114, 0.25);
  --text-main: #1a1a1a;
  --text-secondary: #666666;
  --text-muted: #999999;
  --text-placeholder: #cccccc;
  --bg-input: #f8f9fa;
  --bg-captcha: #f5f5f5;
  --error-color: #ff3b30;
}

.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  padding: 0 48rpx;
  /* 增加底部安全区距离适配 */
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

/* Header 区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  margin-bottom: 100rpx;
}

.title-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.title-black {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--text-main);
}

.title-yellow {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--text-main);
  position: relative;
  z-index: 1;
}

.title-yellow::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 8rpx;
  height: 24rpx;
  background: var(--primary-color);
  z-index: -1;
  border-radius: 12rpx;
}

.subtitle {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 1rpx;
}

/* 表单区域 */
.form-container {
  flex: 1;
  display: block;
  /* 保证 form 标签正确撑开 */
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.input {
  width: 100%;
  height: 96rpx;
  background: var(--bg-input);
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-main);
  box-sizing: border-box;
  transition: all 0.3s;
}

.input:focus {
  background: #ffffff;
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx var(--primary-color-light);
}

.input::placeholder {
  color: var(--text-placeholder);
}

/* 验证码 */
.captcha-row {
  display: flex;
  gap: 16rpx;
}

.captcha-input {
  flex: 1;
}

.captcha-wrapper {
  width: 200rpx;
  height: 96rpx;
  background: var(--bg-captcha);
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.captcha-image {
  width: 100%;
  height: 100%;
}

.captcha-placeholder {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 记住密码 */
.remember-group {
  display: flex;
  align-items: center;
  margin: 24rpx 0 48rpx;
}

.remember-switch {
  transform: scale(0.8);
  margin-right: 8rpx;
}

.remember-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 登录按钮 */
.login-btn {
  background: var(--primary-color);
  color: var(--text-main);
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 50rpx;
  padding: 0;
  height: 100rpx;
  line-height: 100rpx;
  border: none;
  width: 100%;
  box-shadow: 0 10rpx 24rpx var(--primary-color-shadow);
  transition: all 0.3s;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 12rpx var(--primary-color-light);
}

.login-btn.loading {
  opacity: 0.6;
}

.login-btn::after {
  border: none;
}

/* 公告入口 */
.announcement-entry {
  margin-top: 24rpx;
  text-align: center;
}

.announcement-link-wrap {
  position: relative;
  display: inline-flex;
  align-items: flex-start;
}

.announcement-dot {
  position: absolute;
  top: 2rpx;
  right: -8rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff4d4f;
}

.announcement-link {
  font-size: 24rpx;
  color: var(--text-main);
  font-weight: 600;
  text-decoration: underline;
}

.announcement-link:active {
  opacity: 0.7;
}

/* 公告弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
}

.modal-header {
  padding: 36rpx 40rpx 24rpx;
  background: #FFFFFF;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111111;
}

.modal-close {
  font-size: 44rpx;
  color: #AAAAAA;
  line-height: 1;
  padding: 16rpx;
  margin: -16rpx -16rpx -16rpx 0;
}

.modal-body {
  padding: 40rpx;
}

.announcement-scroll {
  max-height: 60vh;
  box-sizing: border-box;
}

.empty-state {
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #AAAAAA;
  letter-spacing: 2rpx;
}

.announcement-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.announcement-item {
  background: #FAFAFC;
  border-radius: 16rpx;
  padding: 24rpx;
  border-left: 8rpx solid #E5E5EA;
}

.announcement-item.type-info {
  border-left-color: #007AFF;
  background: #F0F8FF;
}

.announcement-item.type-warning {
  border-left-color: #FF9500;
  background: #FFF9F0;
}

.announcement-item.type-error {
  border-left-color: #FF3B30;
  background: #FFF0F0;
}

.announcement-item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.announcement-item-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111111;
  flex: 1;
  margin-right: 16rpx;
  line-height: 1.3;
}

.announcement-item-date {
  font-size: 22rpx;
  color: #888888;
  white-space: nowrap;
}

.announcement-item-content {
  font-size: 26rpx;
  color: #444444;
  line-height: 1.5;
}

/* 错误信息 */
.error-msg {
  margin-top: 32rpx;
  text-align: center;
  color: var(--error-color);
  font-size: 26rpx;
}

/* 底部 */
.footer {
  padding: 48rpx 0;
  display: flex;
  justify-content: center;
}

.footer-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.footer-link {
  font-size: 24rpx;
  color: var(--text-main);
  font-weight: 600;
}

.footer-link:active {
  opacity: 0.7;
}

.footer-divider {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

/* 自动登录提示 */
.auto-login-tip {
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
}

.auto-login-tip text {
  color: var(--text-main);
  font-size: 24rpx;
  background: var(--primary-color);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}