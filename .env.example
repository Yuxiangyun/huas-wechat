# Server
PORT=3000
NODE_ENV=production

# JWT secret (MUST change in production)
JWT_SECRET=your-random-secret-at-least-32-chars

# Database
DB_PATH=./data/huas.db

# Logging
LOG_LEVEL=info

# Timezone (fixed to Beijing time)
TIMEZONE=Asia/Shanghai
TZ=Asia/Shanghai

# Per-user max grade cache entries (LRU eviction)
GRADES_CACHE_LIMIT=20

# Per-user max schedule cache entries (LRU eviction)
SCHEDULE_CACHE_LIMIT=120
PORTAL_SCHEDULE_CACHE_LIMIT=120

# Business upstream retry
BUSINESS_RETRY_MAX_ATTEMPTS=2
BUSINESS_RETRY_BASE_DELAY_MS=200
BUSINESS_RETRY_MAX_DELAY_MS=800
BUSINESS_RETRY_JITTER_MS=100
