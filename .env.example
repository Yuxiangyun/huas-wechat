# Server
PORT=3000
NODE_ENV=production

# JWT secret (MUST change in production)
JWT_SECRET=your-random-secret-at-least-32-chars

# Admin Basic Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-deploy
ADMIN_AUTH_REALM=Campus Admin

# Database
DB_PATH=./data/app.db

# Logging
LOG_LEVEL=info

# Timezone (fixed to Beijing time)
TIMEZONE=Asia/Shanghai
TZ=Asia/Shanghai

# Per-user max grade cache entries (LRU eviction)
GRADES_CACHE_LIMIT=20

# Per-user max schedule cache entries (LRU eviction)
SCHEDULE_CACHE_LIMIT=120
PORTAL_SCHEDULE_CACHE_LIMIT=120

# Business upstream retry
BUSINESS_RETRY_MAX_ATTEMPTS=2
BUSINESS_RETRY_BASE_DELAY_MS=200
BUSINESS_RETRY_MAX_DELAY_MS=800
BUSINESS_RETRY_JITTER_MS=100

# Upstream campus services (replace with your own deployment target)
UPSTREAM_CAS_BASE_URL=https://cas.example.edu.cn
UPSTREAM_PORTAL_BASE_URL=https://portal.example.edu.cn
UPSTREAM_JW_BASE_URL=https://jw.example.edu.cn
UPSTREAM_AUTHX_BASE_URL=https://auth.example.edu.cn
UPSTREAM_JW_TARGET_URL=https://jw.example.edu.cn/index.jsp

# Optional per-endpoint overrides for campuses with non-standard paths
# UPSTREAM_CAS_LOGIN_URL=
# UPSTREAM_CAS_CAPTCHA_URL=
# UPSTREAM_CAS_PUBKEY_URL=
# UPSTREAM_PORTAL_LOGIN_URL=
# UPSTREAM_JW_SSO_URL=
# UPSTREAM_JW_INDEX_URL=
# UPSTREAM_JW_SCHEDULE_URL=
# UPSTREAM_JW_GRADE_URL=
# UPSTREAM_PORTAL_ECARD_URL=
# UPSTREAM_AUTHX_USER_URL=
# UPSTREAM_PORTAL_SCHEDULE_URL=
# UPSTREAM_PORTAL_ORIGIN=
# UPSTREAM_PORTAL_REFERER=
# UPSTREAM_SESSION_EXPIRED_HOST=

# Discover media
DISCOVER_STORAGE_ROOT=./data/discover
DISCOVER_MEDIA_BASE_PATH=/media/discover
DISCOVER_MAX_IMAGES=9
DISCOVER_MAX_TAGS=6
DISCOVER_MAX_TITLE_LENGTH=80
DISCOVER_MAX_TAG_LENGTH=12
DISCOVER_MAX_STORE_NAME_LENGTH=32
DISCOVER_MAX_PRICE_TEXT_LENGTH=20
DISCOVER_MAX_CONTENT_LENGTH=400
DISCOVER_MAX_COMMENT_LENGTH=200
DISCOVER_DEFAULT_COMMENT_PAGE_SIZE=50
DISCOVER_MAX_COMMENT_PAGE_SIZE=100
DISCOVER_IMAGE_MAX_BYTES=8388608
DISCOVER_IMAGE_MAX_DIMENSION=1280
DISCOVER_IMAGE_QUALITY=78

# Treehole
TREEHOLE_MAX_POST_LENGTH=500
TREEHOLE_MAX_COMMENT_LENGTH=200
TREEHOLE_DEFAULT_PAGE_SIZE=20
TREEHOLE_MAX_PAGE_SIZE=50
TREEHOLE_DEFAULT_COMMENT_PAGE_SIZE=50
TREEHOLE_MAX_COMMENT_PAGE_SIZE=100
TREEHOLE_AVATAR_STORAGE_ROOT=./data/treehole-avatars
TREEHOLE_AVATAR_MEDIA_BASE_PATH=/media/treehole-avatar
TREEHOLE_AVATAR_MAX_BYTES=2097152
