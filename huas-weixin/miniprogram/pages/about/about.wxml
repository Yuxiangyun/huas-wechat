<view class="about-container" style="{{themeStyle}}">
  <view class="hero-section">
    <view class="title-row">
      <text class="title-black">{{brandPrimary}}</text>
      <text class="title-yellow">{{brandSecondary}}</text>
    </view>
    <text class="subtitle">{{greetingText}}</text>
  </view>
  <view class="content-area">
    <view class="section">
      <view class="section-title">Feedback & Share</view>
      <view class="list-card">
        <button class="list-row list-row-btn" open-type="share" hover-class="row-hover">
          <view class="list-content">
            <text class="list-row-label">推荐给好友</text>
            <text class="list-row-hint">觉得还行？推荐给你的朋友吧</text>
          </view>
          <view class="list-row-tag">分享</view>
        </button>
        <view class="list-row" bindtap="copyWechat" hover-class="row-hover">
          <view class="list-content">
            <text class="list-row-label">{{contactLabel}}</text>
            <text class="list-row-hint">{{contactHint}}</text>
          </view>
          <view class="list-row-tag">{{copyTagText}}</view>
        </view>
      </view>
    </view>
    <view class="section">
      <view class="section-title">Features</view>
      <view class="list-card">
        <view class="list-row" wx:for="{{features}}" wx:key="label">
          <view class="list-content">
            <text class="list-row-label">{{item.label}}</text>
            <text class="list-row-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="section">
      <view class="section-title">Contributors</view>
      <view class="list-card contributors-card">
        <view
          class="contributor-summary contributor-summary-toggle {{contributorsExpanded ? 'expanded' : ''}}"
          bindtap="toggleContributors"
          hover-class="row-hover"
        >
          <view class="contributor-summary-main">
            <text class="contributor-summary-count">{{contributors.length}}</text>
            <view class="contributor-summary-copy">
              <text class="contributor-summary-label">位贡献者</text>
              <text class="contributor-summary-note">{{contributorsNote}}</text>
            </view>
          </view>
          <view class="contributor-summary-action">
            <text class="list-row-tag contributor-toggle-tag">{{contributorsExpanded ? '收起' : '展开'}}</text>
            <text class="contributor-toggle-arrow {{contributorsExpanded ? 'expanded' : ''}}">›</text>
          </view>
        </view>
        <view wx:if="{{contributorsExpanded}}" class="contributor-row" wx:for="{{contributors}}" wx:key="name">
          <view class="contributor-avatar">{{item.initial}}</view>
          <view class="contributor-content">
            <view class="contributor-head">
              <text class="contributor-name">{{item.name}}</text>
              <text class="contributor-role">{{item.role}}</text>
            </view>
            <text class="contributor-desc">{{item.desc}}</text>
          </view>
          <view class="list-row-tag contributor-tag">{{item.tag}}</view>
        </view>
      </view>
    </view>
    <view class="section">
      <view class="section-title">Instructions</view>
      <view class="list-card">
        <view class="list-row" wx:for="{{instructions}}" wx:key="*this">
          <view class="list-content">
            <text class="list-row-text">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="section">
      <view class="section-title">Disclaimer</view>
      <view class="list-card">
        <view class="disclaimer-row">
          <text>本小程序仅供学习交流使用，未存储任何敏感信息。</text>
        </view>
      </view>
    </view>
  </view>
  <view class="footer">
    <text class="footer-text">{{footerText}}</text>
  </view>
</view>
