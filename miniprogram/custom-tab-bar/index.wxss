.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: white;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  /* 用微阴影代替生硬的 border */
  border-top: 1px solid rgba(0, 0, 0, 0.02);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.03);
  z-index: 9999;
}

.tab-bar-item {
  flex: 1;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
}

.tab-text-container {
  width: 120rpx;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 40rpx;
  /* 移除了 transition: all 0.2s ease; 消除切换时的“飞行动画”导致的第二次鬼影 */
}

.tab-text {
  font-size: 32rpx;
  color: #999999;
  font-weight: 500;
}

/* 选中态设计：印章风格 */
.tab-bar-item.active .tab-text-container {
  background-color: #1a1a1a;
}

.tab-bar-item.active .tab-text {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
}