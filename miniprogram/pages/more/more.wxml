<view class="more-container" style="{{themeStyle}}">
  <view class="hero-section">
    <view class="title-row">
      <text class="title-black">Hi,</text>
      <text class="title-yellow">{{userInfo.name || '同学'}}</text>
    </view>
    <text class="subtitle">
      {{userInfo.className || '暂未获取班级信息'}} · 学号 {{userInfo.studentId || '暂未获取'}}
    </text>
  </view>
  <view class="content-area dashboard-content">
    <view class="section section-tight">
      <view class="section-heading">
        <text class="section-title-cn">详情面板</text>
      </view>
      <view class="detail-stack">
        <view wx:if="{{showGrades}}" class="panel-card">
          <view class="panel-head">
            <view class="panel-title-wrap">
              <text class="panel-title">成绩单</text>
              <text class="panel-subtitle">历史成绩、学分与平均绩点</text>
            </view>
            <view class="panel-action" bindtap="refreshGrades">刷新</view>
          </view>
          <view class="panel-body">
            <view wx:if="{{gradesRefreshing}}" class="updated-at-hint updated-at-loading">
              <text>刷新中...</text>
            </view>
            <view wx:elif="{{gradesRefreshHint && !gradesLoading}}" class="updated-at-hint">
              {{gradesRefreshHint}}
            </view>
            <view wx:elif="{{gradesUpdatedAtText && !gradesLoading}}" class="updated-at-hint">
              最近更新 · {{gradesUpdatedAtText}}
            </view>
            <view wx:if="{{gradesLoading}}" class="skeleton-list">
              <view class="skeleton-summary-item" wx:for="{{2}}" wx:key="*this"></view>
              <view class="skeleton-list-item" wx:for="{{3}}" wx:key="*this"></view>
            </view>
            <block wx:elif="{{grades.summary}}">
              <view class="grades-summary">
                <view class="summary-item">
                  <text class="summary-label">累计学分</text>
                  <text class="summary-value">{{grades.summary.totalCredits || 0}}</text>
                </view>
                <view class="summary-item">
                  <text class="summary-label">平均绩点</text>
                  <text class="summary-value highlight">{{grades.summary.averageGpa || '--'}}</text>
                </view>
              </view>
              <scroll-view class="grades-list" scroll-y>
                <block wx:for="{{gradesByTerm}}" wx:key="term">
                  <view class="term-header">
                    <text>{{item.term}}</text>
                  </view>
                  <view wx:for="{{item.items}}" wx:for-item="grade" wx:key="courseCode" class="grade-item">
                    <view class="grade-left">
                      <text class="grade-name">{{grade.courseName}}</text>
                      <text class="grade-code">
                        {{grade.courseCode}} · {{grade.courseNature || grade.courseCategory}}
                      </text>
                    </view>
                    <view class="grade-right">
                      <text class="grade-score {{grade.pass ? 'pass' : 'fail'}}">
                        {{grade.scoreText}}
                      </text>
                      <text class="grade-detail">
                        学分 {{grade.credit}} · 绩点 {{grade.gpa || '--'}}
                      </text>
                    </view>
                  </view>
                </block>
              </scroll-view>
            </block>
            <view wx:else class="empty-state-mini">
              <text class="empty-text">暂无成绩数据</text>
            </view>
          </view>
        </view>

        <view wx:if="{{showECard}}" class="panel-card">
          <view class="panel-head">
            <view class="panel-title-wrap">
              <text class="panel-title">校园卡</text>
              <text class="panel-subtitle">查看余额与最近同步状态</text>
            </view>
            <view class="panel-action" bindtap="refreshECard">刷新</view>
          </view>
          <view class="panel-body">
            <view wx:if="{{ecardRefreshing}}" class="updated-at-hint updated-at-loading">
              <text>刷新中...</text>
            </view>
            <view wx:elif="{{ecardRefreshHint && !ecardLoading}}" class="updated-at-hint">
              {{ecardRefreshHint}}
            </view>
            <view wx:elif="{{ecardUpdatedAtText && !ecardLoading}}" class="updated-at-hint">
              最近更新 · {{ecardUpdatedAtText}}
            </view>
            <view wx:if="{{ecardLoading}}" class="skeleton-ecard">
              <view class="skeleton-label"></view>
              <view class="skeleton-balance"></view>
            </view>
            <view wx:elif="{{ecard}}" class="ecard-info">
              <view class="ecard-balance">
                <text class="balance-label">当前余额</text>
                <text class="balance-value">¥{{ecard.balance}}</text>
              </view>
            </view>
            <view wx:else class="empty-state-mini">
              <text class="empty-text">暂无校园卡数据</text>
            </view>
          </view>
        </view>

        <view wx:if="{{showCustomCourses}}" class="panel-card">
          <view class="panel-head">
            <view class="panel-title-wrap">
              <text class="panel-title">自定义课程</text>
              <text class="panel-subtitle">已添加 {{customCourses.length}} 门自定义安排</text>
            </view>
            <view class="panel-action" bindtap="showAddModal">添加</view>
          </view>
          <view class="panel-body">
            <view wx:if="{{customCourseGroups.length > 0}}">
              <view class="cc-group" wx:for="{{customCourseGroups}}" wx:key="id" wx:for-item="group">
                <view class="cc-group-header">
                  <view class="cc-group-title">
                    <text class="cc-group-name">{{group.name}}</text>
                    <text class="cc-group-teacher" wx:if="{{group.teacher}}">{{group.teacher}}</text>
                  </view>
                  <view class="cc-group-delete" catchtap="deleteCustomCourseGroup" data-groupid="{{group.id}}">
                    删除
                  </view>
                </view>
                <view class="cc-slot-list">
                  <view class="cc-slot-card" wx:for="{{group.items}}" wx:key="customId" wx:for-item="slot">
                    <view class="cc-slot-content">
                      <text class="cc-slot-time">周{{slot.dayStr}} {{slot.section}}</text>
                      <text class="cc-slot-location" wx:if="{{slot.location}}">
                        {{slot.location}}
                      </text>
                    </view>
                    <view class="cc-slot-weeks">
                      <text>{{slot.weeksText}}</text>
                    </view>
                  </view>
                </view>
              </view>
              <view class="list-row cc-clear-all" bindtap="clearAllCustomCourses" hover-class="row-hover" hover-start-time="0" hover-stay-time="150">
                <text class="danger-text">清除全部自定义课程</text>
              </view>
            </view>
            <view wx:else class="empty-state-mini">
              <text class="empty-text">暂无数据，点击右上角「添加」</text>
            </view>
          </view>
        </view>

        <view wx:if="{{showScheduleThemes}}" class="panel-card">
          <view class="panel-head">
            <view class="panel-title-wrap">
              <text class="panel-title">课表主题</text>
              <text class="panel-subtitle">当前为 {{currentScheduleThemeName}}</text>
            </view>
          </view>
          <view class="panel-body theme-panel-body">
            <view class="theme-card">
              <view class="theme-grid">
                <view
                  class="theme-option {{currentScheduleThemeKey === item.key ? 'selected' : ''}}"
                  wx:for="{{scheduleThemeOptions}}"
                  wx:key="key"
                  data-key="{{item.key}}"
                  bindtap="onScheduleThemeSelect"
                >
                  <view class="theme-swatch" style="background: {{item.accent}};"></view>
                  <view class="theme-meta">
                    <text class="theme-name">{{item.name}}</text>
                    <text class="theme-desc">{{item.description}}</text>
                  </view>
                  <text class="theme-check" wx:if="{{currentScheduleThemeKey === item.key}}">✓</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <view wx:if="{{!showGrades && !showECard && !showCustomCourses && !showScheduleThemes}}" class="empty-dashboard-panel">
          <text class="empty-dashboard-title">点击上方服务卡片查看详情</text>
          <text class="empty-dashboard-subtitle">成绩、校园卡、自定义课程和主题设置会显示在这里</text>
        </view>
      </view>
    </view>

    <view class="section section-tight">
      <view class="section-heading">
        <text class="section-title-cn">常用服务</text>
        <text class="section-desc">常查数据与快捷入口</text>
      </view>
      <view class="quick-grid">
        <view class="quick-card {{showGrades ? 'active' : ''}}" bindtap="toggleGrades">
          <text class="quick-title">成绩单</text>
          <text class="quick-desc">历史成绩、学分与绩点</text>
          <view class="quick-foot">
            <text class="quick-meta">{{grades ? '已加载成绩数据' : '点击查看详情'}}</text>
            <text class="quick-badge">{{showGrades ? '收起' : '打开'}}</text>
          </view>
        </view>
        <view class="quick-card {{showECard ? 'active' : ''}}" bindtap="toggleECard">
          <text class="quick-title">校园卡</text>
          <text class="quick-desc">余额与同步状态</text>
          <view class="quick-foot">
            <text class="quick-meta">{{ecard ? '已载入余额信息' : '点击查看详情'}}</text>
            <text class="quick-badge">{{showECard ? '收起' : '打开'}}</text>
          </view>
        </view>
        <view class="quick-card {{showCustomCourses ? 'active' : ''}}" bindtap="toggleCustomCourses">
          <text class="quick-title">自定义课程</text>
          <text class="quick-desc">灵活补充课表安排</text>
          <view class="quick-foot">
            <text class="quick-meta">已添加 {{customCourses.length}} 门</text>
            <text class="quick-badge">{{showCustomCourses ? '收起' : '打开'}}</text>
          </view>
        </view>
        <view class="quick-card" bindtap="openCampusMap">
          <text class="quick-title">校园地图</text>
          <text class="quick-desc">查看东校区与西校区</text>
          <view class="quick-foot">
            <text class="quick-meta">快速查找位置</text>
            <text class="quick-badge">进入</text>
          </view>
        </view>
        <view class="quick-card {{showScheduleThemes ? 'active' : ''}}" bindtap="toggleScheduleThemes">
          <text class="quick-title">课表主题</text>
          <text class="quick-desc">切换首页色彩风格</text>
          <view class="quick-foot">
            <text class="quick-meta">当前 {{currentScheduleThemeName}}</text>
            <text class="quick-badge">{{showScheduleThemes ? '收起' : '打开'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section section-tight">
      <view class="section-heading">
        <text class="section-title-cn">设置与账户</text>
      </view>
      <view class="settings-card">
        <view class="setting-row" bindtap="handleClearCache" hover-class="row-hover" hover-start-time="0" hover-stay-time="150">
          <view class="setting-text-group">
            <text class="setting-title">清除缓存</text>
            <text class="setting-hint">保留登录状态、账号信息与自定义课程</text>
          </view>
          <view class="setting-badge">清除</view>
        </view>
        <view class="setting-row" bindtap="handleLogout" hover-class="row-hover" hover-start-time="0" hover-stay-time="150">
          <view class="setting-text-group">
            <text class="setting-title danger-text">退出登录</text>
            <text class="setting-hint">清除本地会话并返回登录页</text>
          </view>
          <view class="setting-badge danger-badge">退出</view>
        </view>
      </view>
    </view>
  </view>
  <view wx:if="{{showAddModal}}" class="modal-mask" bindtap="hideAddModal">
    <view class="modal-popup" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">自定义课程</text>
        <view class="modal-close" bindtap="hideAddModal">×</view>
      </view>
      <scroll-view scroll-y class="modal-body">
        <view class="modal-content">
          <view class="form-group">
            <text class="form-label">课程名称 *</text>
            <input class="form-input" always-embed="{{true}}" placeholder-class="form-input-placeholder" placeholder="请输入课程名称" value="{{formName}}" bindinput="onFormInput" data-field="formName" />
          </view>
          <view class="form-group">
            <text class="form-label">教师 (选填)</text>
            <input class="form-input" always-embed="{{true}}" placeholder-class="form-input-placeholder" placeholder="请输入授课教师" value="{{formTeacher}}" bindinput="onFormInput" data-field="formTeacher" />
          </view>
          <view class="form-group">
            <text class="form-label">地点 (选填)</text>
            <input class="form-input" always-embed="{{true}}" placeholder-class="form-input-placeholder" placeholder="请输入上课地点" value="{{formLocation}}" bindinput="onFormInput" data-field="formLocation" />
          </view>
          <view class="form-group">
            <text class="form-label">上课时间 (节次)</text>
            <view class="time-slots-container">
              <view class="time-slot-item" wx:for="{{formTimeSlots}}" wx:key="index">
                <picker class="slot-picker flex-day" mode="selector" range="{{dayOptions}}" value="{{item.dayIndex}}" bindchange="onTimeSlotDayChange" data-index="{{index}}">
                  <view class="form-picker">
                    <text>{{dayOptions[item.dayIndex]}}</text>
                    <text class="picker-arrow">▼</text>
                  </view>
                </picker>
                <picker class="slot-picker flex-section" mode="selector" range="{{sectionNumbers}}" value="{{item.startIndex}}" bindchange="onTimeSlotStartChange" data-index="{{index}}">
                  <view class="form-picker">
                    <text>{{sectionNumbers[item.startIndex]}}</text>
                    <text class="picker-arrow">▼</text>
                  </view>
                </picker>
                <text class="slot-to">至</text>
                <picker class="slot-picker flex-section" mode="selector" range="{{sectionNumbers}}" value="{{item.endIndex}}" bindchange="onTimeSlotEndChange" data-index="{{index}}">
                  <view class="form-picker">
                    <text>{{sectionNumbers[item.endIndex]}}</text>
                    <text class="picker-arrow">▼</text>
                  </view>
                </picker>
                <view class="slot-delete" catchtap="removeTimeSlot" data-index="{{index}}" wx:if="{{formTimeSlots.length > 1}}">
                  <text>-</text>
                </view>
              </view>
              <view class="add-slot-btn" bindtap="addTimeSlot">+ 添加时段</view>
            </view>
          </view>
          <view class="form-group">
            <view class="week-header">
              <text class="form-label">生效周次</text>
              <view class="week-actions">
                <text class="week-action-btn" bindtap="selectAllWeeks">全选</text>
                <text class="week-action-btn" bindtap="selectOddWeeks">单周</text>
                <text class="week-action-btn" bindtap="selectEvenWeeks">双周</text>
                <text class="week-action-btn danger" bindtap="clearAllWeeks">清空</text>
              </view>
            </view>
            <view class="week-grid">
              <view class="week-chip {{formWeeks[index + 1] ? 'selected' : ''}}" wx:for="{{20}}" wx:key="index" bindtap="onWeekToggle" data-week="{{index + 1}}">
                <text>{{index + 1}}</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="modal-cancel-btn" bindtap="hideAddModal">取消</view>
        <view class="modal-submit-btn" bindtap="submitCustomCourse">保存</view>
      </view>
    </view>
  </view>
</view>
