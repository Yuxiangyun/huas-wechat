page {
  background: #F9F9FB;
  /* 极浅冷灰色 */
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', sans-serif;
}

.more-container {
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ================= 头部 Hero Section ================= */
.hero-section {
  padding: 100rpx 48rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.title-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.title-black {
  font-size: 64rpx;
  font-weight: 800;
  color: #111111;
  letter-spacing: 2rpx;
}

.title-yellow {
  font-size: 64rpx;
  font-weight: 800;
  color: #111111;
  position: relative;
  z-index: 1;
  letter-spacing: 2rpx;
}

.title-yellow::after {
  content: '';
  position: absolute;
  left: 0;
  right: -8rpx;
  bottom: 8rpx;
  height: 24rpx;
  background: #D2FF72;
  z-index: -1;
  border-radius: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #888888;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* ================= 核心卡片布局 ================= */
.content-area {
  padding: 0 32rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  padding: 0 16rpx 12rpx;
  font-size: 22rpx;
  color: #AAAAAA;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.list-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

/* 列表行 */
.list-row {
  position: relative;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: background-color 0.2s ease;
}

.row-hover {
  background-color: #F4F4F5 !important;
}

.list-content {
  flex: 1;
  padding-right: 32rpx;
}

.list-row-label {
  display: block;
  font-size: 30rpx;
  color: #111111;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.list-row-hint {
  display: block;
  font-size: 24rpx;
  color: #888888;
  line-height: 1.4;
}

/* 胶囊标签 / Pill Shape */
.list-row-tag {
  flex-shrink: 0;
  background: #D2FF72;
  color: #111111;
  font-size: 22rpx;
  font-weight: 700;
  padding: 10rpx 28rpx;
  border-radius: 100rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.toggle-arrow {
  font-size: 24rpx;
  color: #CCCCCC;
}

.danger-text {
  color: #FF3B30 !important;
}

/* ================= 展开内容区 ================= */
.expanded-wrapper {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.expanded-wrapper.show {
  grid-template-rows: 1fr;
}

.expanded-content {
  min-height: 0;
  overflow: hidden;
  background: #FAFAFC;
  opacity: 0;
  transition: opacity 0.2s ease, border-top-color 0.25s ease;
  border-top: 1rpx solid transparent;
}

.expanded-wrapper.show .expanded-content {
  opacity: 1;
  border-top-color: rgba(0, 0, 0, 0.03);
}

.loading-text {
  text-align: center;
  padding: 48rpx;
  color: #AAAAAA;
  font-size: 26rpx;
}

/* ================= 骨架屏动画与样式 ================= */
@keyframes skeletonPulse {
  0% {
    opacity: 0.6;
  }

  50% {
    opacity: 1;
  }

  100% {
    opacity: 0.6;
  }
}

.skeleton-list {
  padding: 32rpx;
}

.skeleton-summary-item {
  height: 80rpx;
  background: #E8E8E8;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  width: 45%;
  display: inline-block;
  animation: skeletonPulse 1.5s ease-in-out infinite;
}

.skeleton-summary-item:nth-child(2) {
  margin-left: 10%;
}

.skeleton-list-item {
  height: 100rpx;
  background: #E8E8E8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  animation: skeletonPulse 1.5s ease-in-out infinite;
}

.skeleton-list-item:nth-child(even) {
  width: 85%;
}

.skeleton-ecard {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.skeleton-label {
  width: 200rpx;
  height: 24rpx;
  background: #E8E8E8;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  animation: skeletonPulse 1.5s ease-in-out infinite;
}

.skeleton-balance {
  width: 300rpx;
  height: 80rpx;
  background: #E8E8E8;
  border-radius: 12rpx;
  animation: skeletonPulse 1.5s ease-in-out infinite;
}

.empty-state-mini {
  padding: 60rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 24rpx;
  color: #AAAAAA;
  letter-spacing: 1rpx;
}

/* 成绩汇总 */
.grades-summary {
  display: flex;
  padding: 32rpx;
  gap: 24rpx;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.summary-label {
  font-size: 20rpx;
  color: #AAAAAA;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.summary-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #111111;
}

/* 成绩列表 */
.grades-list {
  max-height: 800rpx;
}

.term-header {
  padding: 16rpx 32rpx;
  background: #F4F4F5;
}

.term-header text {
  font-size: 22rpx;
  color: #888888;
  font-weight: 600;
}

.grade-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
  background: #FFFFFF;
}

.grade-left {
  flex: 1;
  margin-right: 20rpx;
}

.grade-name {
  display: block;
  font-size: 28rpx;
  color: #111111;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.grade-code {
  display: block;
  font-size: 22rpx;
  color: #AAAAAA;
}

.grade-right {
  text-align: right;
}

.grade-score {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
}

.grade-score.pass {
  color: #111111;
}

.grade-score.fail {
  color: #FF3B30;
}

.grade-detail {
  display: block;
  font-size: 20rpx;
  color: #AAAAAA;
  margin-top: 4rpx;
}

/* 自定义课程列表 */
.cc-group {
  padding: 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
}

.cc-group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.cc-group-title {
  display: flex;
  align-items: center;
}

.cc-group-name {
  font-size: 30rpx;
  color: #111111;
  font-weight: 600;
}

.cc-group-teacher {
  font-size: 20rpx;
  color: #888888;
  background: #F4F4F5;
  padding: 6rpx 12rpx;
  /* 稍微调整上下 padding 使其更协调 */
  border-radius: 8rpx;
  margin-left: 16rpx;

  /* 新增以下属性保证居中和对齐 */
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.cc-group-delete {
  font-size: 22rpx;
  color: #FF3B30;
  font-weight: 600;
}

.cc-slot-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cc-slot-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #F9F9FB;
  border-radius: 12rpx;
  padding: 24rpx;
  border-left: 6rpx solid #D2FF72;
}

.cc-slot-time {
  display: block;
  font-size: 26rpx;
  color: #111111;
  font-weight: 600;
}

.cc-slot-location {
  display: block;
  font-size: 22rpx;
  color: #888888;
  margin-top: 6rpx;
}

.cc-slot-weeks {
  background: #FFFFFF;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  color: #111111;
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.cc-clear-all {
  justify-content: center;
  background: #FFFFFF;
}

/* 校园卡 */
.ecard-info {
  padding: 48rpx 32rpx;
  text-align: center;
  background: #FFFFFF;
}

.balance-label {
  display: block;
  font-size: 20rpx;
  color: #AAAAAA;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.balance-value {
  display: block;
  font-size: 72rpx;
  font-weight: 800;
  color: #111111;
  letter-spacing: -2rpx;
}

/* ================= 弹窗样式 (融入极简风格) ================= */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99999;
}

.modal-popup {
  width: 680rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  background: #FFFFFF;
  padding: 36rpx 32rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111111;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #AAAAAA;
  font-size: 44rpx;
}

.modal-body {
  width: 100%;
  height: 60vh;
}

.modal-content {
  padding: 32rpx;
  box-sizing: border-box;
}

.form-group {
  margin-bottom: 36rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 16rpx;
  display: block;
}

.form-input,
.form-picker {
  width: 100%;
  height: 88rpx;
  background: #F9F9FB;
  border: 1px solid rgba(0, 0, 0, 0.04);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #111111;
  box-sizing: border-box;
}

.form-input-placeholder {
  color: #BBBBBB;
}

/* 弹窗底部按钮 */
.modal-footer {
  display: flex;
  padding: 24rpx 32rpx 32rpx;
  gap: 20rpx;
  background: #FFFFFF;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.modal-cancel-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F4F4F5;
  color: #111111;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 100rpx;
  /* Pill Shape */
}

.modal-submit-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #D2FF72;
  /* 替换为亮黄色背景 */
  color: #111111;
  /* 替换为深黑色文字 */
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 100rpx;
  /* Pill Shape */
}

/* 自定义排课选择器附属样式 */
.time-slots-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.time-slot-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.slot-picker {
  height: 88rpx;
  display: block;
  position: relative;
}

.flex-day {
  flex: 1.2;
}

.flex-section {
  flex: 0.9;
}

.slot-to {
  font-size: 26rpx;
  color: #888888;
  margin: 0 4rpx;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  pointer-events: none;
}

.picker-arrow {
  font-size: 20rpx;
  color: #CCCCCC;
}

.slot-delete {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF5F5;
  border-radius: 12rpx;
}

.slot-delete text {
  color: #FF3B30;
  font-size: 44rpx;
  font-weight: 300;
  margin-top: -4rpx;
}

.add-slot-btn {
  font-size: 26rpx;
  font-weight: 600;
  color: #111111;
  text-align: center;
  height: 88rpx;
  line-height: 84rpx;
  border: 1rpx dashed rgba(0, 0, 0, 0.1);
  border-radius: 12rpx;
  margin-top: 8rpx;
}

/* 快捷周次按钮 */
.week-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.week-header .form-label {
  margin-bottom: 0;
}

.week-actions {
  display: flex;
  gap: 12rpx;
}

.week-action-btn {
  font-size: 20rpx;
  font-weight: 600;
  color: #111111;
  background: #F4F4F5;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.week-action-btn.danger {
  color: #FF3B30;
  background: #FFF5F5;
}

.week-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
}

.week-chip {
  width: 100%;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F9F9FB;
  border-radius: 10rpx;
  border: 1px solid rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.week-chip text {
  font-size: 26rpx;
  color: #888888;
}

.week-chip.selected {
  background: #D2FF72;
  /* 替换为亮黄色背景 */
  border-color: #D2FF72;
}

.week-chip.selected text {
  color: #111111;
  /* 替换为深黑色文字 */
  font-weight: 600;
}