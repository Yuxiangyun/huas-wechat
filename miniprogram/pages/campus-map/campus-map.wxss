page {
  background: #edf1e4;
}

.campus-map-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(210, 255, 114, 0.16), transparent 34%),
    linear-gradient(180deg, #f7f8f2 0%, #ecf0e5 100%);
}

.map-stage {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.map-area {
  width: 100%;
  height: 100%;
}

.map-view {
  position: absolute;
  left: 0;
  top: 0;
}

.map-surface {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: 28rpx;
  background: #f6f1de;
  box-shadow: 0 22rpx 60rpx rgba(17, 17, 17, 0.14);
}

.map-image,
.map-fallback,
.map-grid-overlay {
  position: absolute;
  inset: 0;
}

.map-image {
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.24s ease;
}

.map-image.visible {
  opacity: 1;
}

.map-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
}

.map-fallback.hidden {
  opacity: 0;
  pointer-events: none;
}

.map-fallback-grid {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(rgba(17, 17, 17, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(17, 17, 17, 0.05) 1px, transparent 1px);
  background-size: 56rpx 56rpx;
  opacity: 0.55;
}

.map-fallback-copy {
  position: relative;
  width: 76%;
  padding: 28rpx 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(10px);
  box-shadow: 0 12rpx 36rpx rgba(17, 17, 17, 0.08);
}

.map-fallback-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #111111;
}

.map-fallback-text {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #666666;
}

.map-fallback-path {
  display: block;
  margin-top: 14rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #7c7c7c;
  word-break: break-all;
}

.map-grid-overlay {
  background:
    linear-gradient(rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.18)),
    linear-gradient(transparent 97%, rgba(17, 17, 17, 0.035) 100%),
    linear-gradient(90deg, transparent 97%, rgba(17, 17, 17, 0.035) 100%);
  background-size: auto, 88rpx 88rpx, 88rpx 88rpx;
  mix-blend-mode: soft-light;
  pointer-events: none;
}

.map-topbar {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 24rpx;
  display: flex;
  justify-content: flex-end;
}

.map-switcher {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-left: auto;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 12rpx 30rpx rgba(17, 17, 17, 0.08);
}

.map-switcher-item {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  color: #666666;
  font-size: 22rpx;
  font-weight: 700;
  background: transparent;
}

.map-switcher-item.active {
  background: var(--theme-accent, #d2ff72);
  color: var(--theme-accent-ink, #111111);
}

.map-actions {
  position: absolute;
  right: 24rpx;
  bottom: calc(312rpx + env(safe-area-inset-bottom));
}

.map-action-btn {
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(17, 17, 17, 0.84);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 36rpx rgba(17, 17, 17, 0.16);
}

.map-status {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 248, 220, 0.92);
  color: #8d6b16;
  font-size: 22rpx;
  line-height: 1.5;
  box-shadow: 0 12rpx 24rpx rgba(17, 17, 17, 0.08);
}
