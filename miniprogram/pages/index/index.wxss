page {

  background: #F9F9FB;

  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', sans-serif;

}



.schedule-container {

  min-height: 100vh;

  display: flex;

  flex-direction: column;

}



/* ================= 头部 Hero Section ================= */

.hero-section {

  padding: 40rpx 32rpx 24rpx;

  display: flex;

  justify-content: space-between;

  align-items: flex-end;

  position: relative;

  z-index: 100;

}



.title-area {

  flex: 1;

  min-width: 0;

  position: relative;

  z-index: 2;

  overflow: visible;

}



.action-area {

  display: flex;

  gap: 16rpx;

  flex-shrink: 0;

  position: relative;

  z-index: 1;

}



.title-row {

  display: flex;

  align-items: center;

}



.title-black {

  font-size: 56rpx;

  font-weight: 800;

  color: #111111;

  letter-spacing: 2rpx;

}



.title-yellow {

  font-size: 56rpx;

  font-weight: 800;

  color: #111111;

  position: relative;

  z-index: 1;

  letter-spacing: 2rpx;

  margin-left: 12rpx;

}



.title-yellow::after {

  content: '';

  position: absolute;

  left: 0;

  right: -8rpx;

  bottom: 8rpx;

  height: 20rpx;

  background: var(--theme-accent, #D2FF72);

  z-index: -1;

  border-radius: 6rpx;

}



.subtitle-row {

  display: flex;

  align-items: center;

  gap: 16rpx;

  margin-top: 8rpx;

  height: 48rpx;

  overflow: visible;

}



.picker-trigger {

  display: flex;

  align-items: center;

  height: 100%;

  position: relative;

  z-index: 5;

  overflow: visible;

  line-height: 1;

}



.subtitle {

  font-size: 22rpx;

  color: #888888;

  font-weight: 600;

  text-transform: uppercase;

  letter-spacing: 2rpx;

  flex-shrink: 0;

  display: flex;

  align-items: center;

  height: 100%;

  line-height: 1;

}



.subtitle-updated {

  margin-top: 4rpx;

  font-size: 20rpx;

  color: #A8A8A8;

  letter-spacing: 0.6rpx;

  line-height: 1.4;

}

.subtitle-updating {

  display: flex;

  align-items: center;

  gap: 8rpx;

}



.source-picker {

  display: flex;

  align-items: center;

  justify-content: center;

  background: rgba(0, 0, 0, 0.04);

  padding: 0 20rpx;

  height: 40rpx;

  border-radius: 8rpx;

  font-size: 20rpx;

  color: #666666;

  font-weight: 600;

  box-sizing: border-box;

  line-height: 1;

}



.source-picker:active {

  background: rgba(0, 0, 0, 0.08);

}



.source-picker .nav-arrow {

  margin-left: 6rpx;

  font-size: 16rpx;

}



.pill-btn {

  background: #111111;

  color: var(--theme-accent, #D2FF72);

  font-size: 24rpx;

  font-weight: 700;

  padding: 12rpx 36rpx;

  border-radius: 100rpx;

  letter-spacing: 1rpx;

  margin-bottom: 8rpx;

}

.announcement-pill {

  position: relative;

}

.announcement-dot {

  position: absolute;

  top: 6rpx;

  right: 10rpx;

  width: 14rpx;

  height: 14rpx;

  border-radius: 50%;

  background: #ff4d4f;

}



/* ================= 导航胶囊 ================= */

.week-nav {

  display: flex;

  padding: 0 32rpx 24rpx;

  gap: 16rpx;

  align-items: center;

}



.nav-pill {

  background: #FFFFFF;

  border: 1rpx solid rgba(0, 0, 0, 0.04);

  padding: 10rpx 24rpx;

  border-radius: 100rpx;

  font-size: 24rpx;

  color: #111111;

  font-weight: 600;

  display: flex;

  align-items: center;

  gap: 6rpx;

  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);

}



.highlight-pill {

  background: var(--theme-accent, #D2FF72);

  border-color: var(--theme-accent, #D2FF72);

  color: var(--theme-accent-ink, #111111);

  padding: 10rpx 32rpx;

}



.nav-arrow {

  font-size: 24rpx;

  color: #888888;

}



.icon-down {

  font-size: 16rpx;

  margin-left: 4rpx;

}



/* ================= 悬浮课表主体 (Scheme A) ================= */

.schedule-scroll {

  flex: 1;

  padding: 0 32rpx calc(140rpx + env(safe-area-inset-bottom));

  box-sizing: border-box;

  width: 100vw;

}



.table-container {

  display: flex;

  flex-direction: column;

  min-width: 1050rpx;

  position: relative;

  background: #FFFFFF;

  background-image: repeating-linear-gradient(45deg, rgba(0, 0, 0, 0.01) 0, rgba(0, 0, 0, 0.01) 2rpx, transparent 2rpx, transparent 16rpx);

  border-radius: 24rpx;

  border: 1rpx solid rgba(0, 0, 0, 0.04);

  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.03);

  overflow: hidden;

  /* 切除圆角 */

}



.table-container.hide-weekend {

  min-width: 100%;

}



.table-container.hide-weekend .day-cell {

  flex: 1;

  min-width: 0;

}



.table-row {

  display: flex;

}



.header-row {

  background: #FAFAFC;

  position: sticky;

  top: 0;

  z-index: 20;

  height: 80rpx;

}



.time-cell {

  width: 80rpx;

  display: flex;

  flex-direction: column;

  align-items: center;

  justify-content: center;

  background: #FAFAFC;

  border-right: 1rpx solid rgba(0, 0, 0, 0.03);

  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);

  position: sticky;

  left: 0;

  z-index: 10;

}



.time-cell.header-cell {

  height: 80rpx;

}



.time-num {

  font-size: 26rpx;

  font-weight: 700;

  color: #111;

}



.time-start {

  font-size: 18rpx;

  color: #AAAAAA;

  margin-top: 4rpx;

}



.time-end {

  font-size: 18rpx;

  color: #AAAAAA;

  margin-top: 2rpx;

}



.day-cell {

  width: 140rpx;

  position: relative;

  border-right: 1rpx solid rgba(0, 0, 0, 0.03);

  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);

}



.header-cell.day-cell {

  height: 80rpx;

  display: flex;

  align-items: center;

  justify-content: center;

}



.day-name {

  font-size: 26rpx;

  color: #888888;

  font-weight: 600;

}



.header-cell.today .day-name {

  color: #111111;

  font-weight: 800;

}



.course-card {

  position: absolute;

  border-radius: 12rpx;

  padding: 10rpx 8rpx;

  display: flex;

  flex-direction: column;

  overflow: hidden;

  box-sizing: border-box;

  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.4), 0 4rpx 12rpx rgba(0, 0, 0, 0.04);

  border: 1rpx solid rgba(0, 0, 0, 0.02);

}



.course-name {

  font-size: 24rpx;

  font-weight: 600;

  color: #111;

  line-height: 1.3;

  margin-bottom: 6rpx;

  display: -webkit-box;

  -webkit-line-clamp: 3;

  -webkit-box-orient: vertical;

  overflow: hidden;

}



.course-location {

  font-size: 20rpx;

  color: #666;

  opacity: 0.85;

  display: -webkit-box;

  -webkit-line-clamp: 2;

  -webkit-box-orient: vertical;

  overflow: hidden;

}



.course-card.custom-card {

  border-left-style: dashed;

  background-image: repeating-linear-gradient(-45deg, rgba(255, 255, 255, 0.4) 0, rgba(255, 255, 255, 0.4) 4rpx, transparent 4rpx, transparent 12rpx);

}



.custom-badge {

  display: none;

}



/* 极简风格下隐藏多余徽章，虚线边框已足够 */



.color-0 {

  background: #F0F7FF;

  border-left: 6rpx solid #91CAFF;

}



.color-1 {

  background: #F6FFED;

  border-left: 6rpx solid #B7EB8F;

}



.color-2 {

  background: #FFF0F6;

  border-left: 6rpx solid #FFADD2;

}



.color-3 {

  background: #FFF2E8;

  border-left: 6rpx solid #FFBB96;

}



.color-4 {

  background: #E6FFFB;

  border-left: 6rpx solid #87E8DE;

}



.color-5 {

  background: #F9F0FF;

  border-left: 6rpx solid #D3ADF7;

}



.color-6 {

  background: #FCFFE6;

  border-left: 6rpx solid #EAF889;

}



.color-7 {

  background: #E0F2FE;

  border-left: 6rpx solid #7DD3FC;

}



.color-8 {

  background: #FEF2F2;

  border-left: 6rpx solid #FECACA;

}



.color-9 {

  background: #ECFDF5;

  border-left: 6rpx solid #6EE7B7;

}



.color-10 {

  background: #FFFBEB;

  border-left: 6rpx solid #FDE047;

}



.color-11 {

  background: #F3E8FF;

  border-left: 6rpx solid #D8B4FE;

}



.color-12 {

  background: #FFE4E6;

  border-left: 6rpx solid #FDA4AF;

}



.color-13 {

  background: #F0FDF4;

  border-left: 6rpx solid #86EFAC;

}



.color-14 {

  background: #F8FAFC;

  border-left: 6rpx solid #CBD5E1;

}



.time-indicator {

  position: absolute;

  left: 0;

  right: 0;

  height: 2rpx;

  background: #FF3B30;

  z-index: 50;

  pointer-events: none;

  box-shadow: 0 0 12rpx rgba(255, 59, 48, 0.8);

}



.time-indicator-dot {

  position: absolute;

  left: -6rpx;

  top: -4rpx;

  width: 10rpx;

  height: 10rpx;

  border-radius: 50%;

  background: #FF3B30;

  box-shadow: 0 0 10rpx rgba(255, 59, 48, 0.8);

}



.time-countdown {

  position: absolute;

  right: 8rpx;

  bottom: 8rpx;

  background: #FF3B30;

  color: #FFFFFF;

  font-size: 16rpx;

  font-weight: 700;

  padding: 4rpx 12rpx;

  border-radius: 100rpx;

  box-shadow: 0 4rpx 12rpx rgba(255, 59, 48, 0.4);

  pointer-events: none;

}



.skeleton-box {

  background: #E8E8E8;

  border-radius: 8rpx;

  opacity: 0.85;

}



.empty-state {

  padding-top: 200rpx;

  text-align: center;

}



.empty-emoji {

  font-size: 80rpx;

  margin-bottom: 20rpx;

  display: block;

}



.empty-text {

  font-size: 26rpx;

  color: #AAAAAA;

  letter-spacing: 2rpx;

}



/* ================= 极简弹窗 ================= */

.modal-mask,

.announcement-modal-mask {

  position: fixed;

  top: 0;

  left: 0;

  right: 0;

  bottom: 0;

  background: rgba(0, 0, 0, 0.4);

  backdrop-filter: blur(6px);

  display: flex;

  align-items: center;

  justify-content: center;

  z-index: 1000;

}



.modal-content {

  width: 600rpx;

  background: #FFFFFF;

  border-radius: 24rpx;

  overflow: hidden;

  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);

  animation: pop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);

}



.announcement-modal {

  width: calc(100vw - 80rpx);

  max-width: 640rpx;

  max-height: 76vh;

  background: #FFFFFF;

  border-radius: 24rpx;

  overflow: hidden;

  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);

  display: flex;

  flex-direction: column;

  animation: pop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);

}



@keyframes pop {

  0% {

    transform: scale(0.85);

    opacity: 0;

  }



  100% {

    transform: scale(1);

    opacity: 1;

  }

}



.modal-header {

  padding: 36rpx 40rpx 24rpx;

  background: #FFFFFF;

  display: flex;

  justify-content: space-between;

  align-items: center;

  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);

}



.announcement-modal-header {

  padding: 32rpx 36rpx 20rpx;

  background: #FFFFFF;

  display: flex;

  justify-content: space-between;

  align-items: center;

  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);

}



.modal-title {

  font-size: 32rpx;

  font-weight: 700;

  color: #111111;

}



.announcement-modal-title {

  font-size: 32rpx;

  font-weight: 700;

  color: #111111;

}



.modal-close {

  font-size: 44rpx;

  color: #AAAAAA;

  line-height: 1;

  padding: 16rpx;

  margin: -16rpx -16rpx -16rpx 0;

}



.announcement-modal-close {

  font-size: 44rpx;

  color: #AAAAAA;

  line-height: 1;

  padding: 16rpx;

  margin: -16rpx -16rpx -16rpx 0;

}



.modal-body {

  padding: 40rpx;

}



.detail-item {

  display: flex;

  flex-direction: column;

  margin-bottom: 32rpx;

}



.detail-item:last-child {

  margin-bottom: 0;

}



.detail-label {

  font-size: 20rpx;

  color: #AAAAAA;

  letter-spacing: 2rpx;

  margin-bottom: 8rpx;

}



.detail-value {

  font-size: 28rpx;

  color: #111111;

  font-weight: 500;

  word-break: break-all;

}



.bold-text {

  font-size: 36rpx;

  font-weight: 700;

  line-height: 1.3;

}



/* ================= 公告弹窗 ================= */

.announcement-modal-scroll {

  flex: 1;

  max-height: 60vh;

  min-height: 220rpx;

  box-sizing: border-box;

  padding: 0 32rpx 32rpx;

}



.announcement-empty-state {

  text-align: center;

  padding: 64rpx 0;

}



.announcement-empty-text {

  font-size: 26rpx;

  color: #AAAAAA;

  letter-spacing: 2rpx;

}



.announcement-list {

  display: flex;

  flex-direction: column;

  gap: 24rpx;

  padding-top: 16rpx;

}



.announcement-item {

  background: #FAFAFC;

  border-radius: 16rpx;

  padding: 24rpx;

  border-left: 8rpx solid #E5E5EA;

}



.announcement-item.type-info {

  border-left-color: #007AFF;

  background: #F0F8FF;

}



.announcement-item.type-warning {

  border-left-color: #FF9500;

  background: #FFF9F0;

}



.announcement-item.type-error {

  border-left-color: #FF3B30;

  background: #FFF0F0;

}



.announcement-item-header {

  display: flex;

  justify-content: space-between;

  align-items: flex-start;

  margin-bottom: 12rpx;

}



.announcement-item-title {

  font-size: 28rpx;

  font-weight: 700;

  color: #111111;

  flex: 1;

  margin-right: 16rpx;

  line-height: 1.3;

}



.announcement-item-date {

  font-size: 22rpx;

  color: #888888;

  white-space: nowrap;

}



.announcement-item-content {

  font-size: 26rpx;

  color: #444444;

  line-height: 1.5;

}
